<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LiveTrack — Real-Time Location</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- ══════════════════════════════════════════
       USERNAME MODAL  (shown on page load)
  ══════════════════════════════════════════ -->
  <div id="username-modal" class="modal-overlay active">
    <div class="modal">
      <div class="modal-brand">
        <span class="brand-icon">◈</span>
        <span class="brand-name">LIVETRACK</span>
      </div>
      <p class="modal-tagline">Real-time location mesh network</p>

      <div class="field">
        <label class="field-label" for="username-input">Callsign</label>
        <input
          id="username-input"
          class="field-input"
          type="text"
          placeholder="Enter your name…"
          maxlength="20"
          autocomplete="off"
          spellcheck="false"
        >
      </div>

      <button id="join-btn" class="deploy-btn">
        <span>DEPLOY TO NETWORK</span>
        <span>→</span>
      </button>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       MAIN APP SHELL
  ══════════════════════════════════════════ -->
  <div id="app">

    <!-- Header bar -->
    <header>
      <div class="hdr-brand">
        <span class="hdr-icon">◈</span>
        <span class="hdr-title">LIVETRACK</span>
      </div>

      <div class="hdr-status">
        <span class="ping-dot"></span>
        <span id="status-text">CONNECTING</span>
      </div>

      <div class="hdr-actions">
        <!-- Toggle side panel open/close -->
        <button id="toggle-panel" class="icon-btn" title="Toggle users panel">☰</button>
      </div>
    </header>

    <!-- Full-screen map -->
    <div id="map"></div>

    <!-- Side panel — list of connected users -->
    <div id="side-panel" class="open">
      <div class="panel-hdr">
        <span>Active Users</span>
        <span id="user-count" class="count-badge">0</span>
      </div>

      <div id="user-list">
        <!-- Populated by script.js -->
      </div>

      <div class="panel-footer">
        <div class="my-callsign">
          <span class="callsign-icon">▲</span>
          <span id="my-name-display">—</span>
        </div>
        <button id="center-btn" class="center-btn">⊕ &nbsp;Centre My Location</button>
      </div>
    </div>

    <!-- Toast notification -->
    <div id="notification"></div>

  </div><!-- /#app -->

  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
